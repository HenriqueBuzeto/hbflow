  updatedAt DateTime @updatedAt
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model Task {
  id             String         @id @default(uuid())
  tenantId       String
  contactId      String?
  dealId         String?
  conversationId String?
  assignedUserId String
