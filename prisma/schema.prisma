generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String               @id @default(uuid())
  name                 String
  slug                 String               @unique
  document             String?
  email                String?
  phone                String?
  status               String               @default("active")
  plan                 String               @default("starter")
  isBlocked            Boolean              @default(false)
  subscriptionStatus   String               @default("active")
  timezone             String               @default("America/Sao_Paulo")
  locale               String               @default("pt_BR")
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  agentConfigs         AgentConfig[]
  agentExecutionLogs   AgentExecutionLog[]
  agentMemories        AgentMemory[]
  apiKeys              ApiKey[]
  auditLogs            AuditLog[]
  automationRules      AutomationRule[]
  businessHours        BusinessHours[]
  campaigns            Campaign[]
  contacts             Contact[]
  conversations        Conversation[]
  deals                Deal[]
  dealLossReasons      DealLossReason[]
  departments          Department[]
  errorLogs            ErrorLog[]
  files                File[]
  flows                Flow[]
  flowSessions         FlowSession[]
  integrations         Integration[]
  loginAuditLogs       LoginAuditLog[]
  templates            MessageTemplate[]
  notifications        Notification[]
  permissions          Permission[]
  pipelines            Pipeline[]
  quickReplies         QuickReply[]
  realtimeEvents       RealtimeEvent[]
  roles                Role[]
  routingFilters       RoutingFilter[]
  slaRules             SlaRule[]
  systemEvents         SystemEvent[]
  tasks                Task[]
  tenantAICost         TenantAICost?
  aiCredits            TenantAICredit[]
  aiUsage              TenantAIUsage[]
  billing              TenantBilling?
  featureFlagOverrides TenantFeatureFlag[]
  planFeatures         TenantPlanFeature[]
  settings             TenantSettings?
  users                User[]
  userPresence         UserPresence[]
  webhookEndpoints     WebhookEndpoint[]
  webhookEvents        WebhookEvent[]
  whatsappConnections  WhatsappConnection[]
  subscriptions        Subscription[]
  invoices             Invoice[]
  payments             Payment[]
  pixCharges           PixCharge[]
  tenantDiscounts      TenantDiscount[]
  journeys             Journey[]
  contactJourneys      ContactJourney[]
  scheduledMessages    ScheduledMessage[]
  journeyEventLogs     JourneyEventLog[]
  internalMessages     InternalMessage[]
}

model TenantSettings {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  brandingName      String?
  brandingLogo      String?
  brandingColor     String?  @default("#7C3AED")
  defaultLanguage   String   @default("pt_BR")
  defaultTimezone   String   @default("America/Sao_Paulo")
  businessHoursJson String?  @default("{}")
  customDomain      String?
  settingsJson      String   @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantBilling {
  id                   String    @id @default(uuid())
  tenantId             String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  billingEmail         String?
  billingAddress       String?
  billingCity          String?
  billingState         String?
  billingZip           String?
  billingCountry       String?
  nextBillingDate      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantAIUsage {
  id           String   @id @default(uuid())
  tenantId     String
  month        String
  provider     String   @default("openai")
  model        String   @default("gpt-4o")
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  costUsd      Float    @default(0.0)
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, month, provider, model])
}

model TenantAICredit {
  id          String    @id @default(uuid())
  tenantId    String
  amount      Float     @default(0.0)
  type        String    @default("purchase")
  description String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantPlanFeature {
  id        String   @id @default(uuid())
  tenantId  String
  feature   String
  value     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, feature])
}

model User {
  id                  String               @id @default(uuid())
  tenantId            String
  name                String
  email               String
  passwordHash        String
  avatarUrl           String?
  signature           String?
  sigPosition         String               @default("end")
  phone               String?
  roleId              String?
  isActive            Boolean              @default(true)
  isOnline            Boolean              @default(false)
  workload            Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  agentExecutionLogs  AgentExecutionLog[]
  auditLogs           AuditLog[]
  responsibleContacts Contact[]            @relation("ContactResponsible")
  conversations       Conversation[]       @relation("AssignedConversations")
  deals               Deal[]
  loginAuditLogs      LoginAuditLog[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  routingLogs         RoutingLog[]
  sessions            Session[]
  tasks               Task[]
  role                Role?                @relation(fields: [roleId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userDepartments     UserDepartment[]
  permissions         UserPermission[]
  presence            UserPresence?
  profile             UserProfile?
  userRoutingFilters  UserRoutingFilter[]
  tenantDiscountsCreated TenantDiscount[]
  sentInternalMessages     InternalMessage[] @relation("SentInternalMessages")
  receivedInternalMessages InternalMessage[] @relation("ReceivedInternalMessages")

  @@unique([tenantId, email])
}

model UserProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  jobTitle    String?
  department  String?
  bio         String?
  birthday    DateTime?
  address     String?
  city        String?
  state       String?
  zip         String?
  country     String?
  preferences String    @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginAuditLog {
  id            String   @id @default(uuid())
  userId        String?
  tenantId      String
  email         String?
  action        String
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  users           User[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Permission {
  id              String           @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  users           UserPermission[]

  @@unique([tenantId, name])
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model WhatsappConnection {
  id                String                    @id @default(uuid())
  tenantId          String
  name              String
  provider          String                    @default("cloud_api")
  instanceName      String?
  phoneNumber       String?
  phoneNumberId     String?
  wabaId            String?
  businessAccountId String?
  accessTokenEnc    String?
  verifyToken       String?
  webhookSecret     String?
  status            String                    @default("disconnected")
  qualityRating     String?
  messagingLimit    Int?
  displayName       String?
  qrCode            String?
  lastQrAt          DateTime?
  connectedAt       DateTime?
  disconnectedAt    DateTime?
  metadataJson          String?                   @default("{}")
  lastWebhookAt         DateTime?
  lastSyncAt            DateTime?
  lastMessageReceivedAt DateTime?
  lastMessageSentAt     DateTime?
  lastWebhookReceivedAt DateTime?
  lastError             String?
  qrcodeExpired         Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  deletedAt             DateTime?
  conversations     Conversation[]            @relation("ChannelConversations")
  apiLogs           WhatsappApiLog[]
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mediaFiles        WhatsappMediaFile[]
  messageTemplates  WhatsappMessageTemplate[]
  webhookEvents     WhatsappWebhookEvent[]
}

model WhatsappWebhookEvent {
  id              String             @id @default(uuid())
  connectionId    String
  providerEventId String             @unique
  eventType       String
  payloadJson     String
  processedAt     DateTime?
  status          String             @default("pending")
  createdAt       DateTime           @default(now())
  connection      WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, status])
}

model WhatsappMessageTemplate {
  id           String             @id @default(uuid())
  connectionId String
  name         String
  category     String
  language     String
  status       String             @default("approved")
  components   String             @default("[]")
  externalId   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  connection   WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model WhatsappMediaFile {
  id           String             @id @default(uuid())
  connectionId String
  fileId       String             @unique
  mimeType     String
  url          String
  size         Int?
  expiresAt    DateTime?
  createdAt    DateTime           @default(now())
  connection   WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model WhatsappApiLog {
  id           String             @id @default(uuid())
  connectionId String
  endpoint     String
  method       String
  requestJson  String?
  responseJson String?
  statusCode   Int?
  durationMs   Int?
  success      Boolean
  errorMessage String?
  createdAt    DateTime           @default(now())
  connection   WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
}

model Contact {
  id                        String                     @id @default(uuid())
  tenantId                  String
  name                      String
  phone                     String
  normalizedPhone           String                     @default("")
  email                     String?
  document                  String?
  type                      String                     @default("lead")
  source                    String                     @default("whatsapp")
  status                    String                     @default("lead")
  temperature               String                     @default("cold")
  score                     Int                        @default(0)
  totalPurchased            Float                      @default(0.0)
  responsibleUserId         String?
  marketingOptOut           Boolean                    @default(false)
  firstInteractionAt        DateTime                   @default(now())
  lastInteractionAt         DateTime                   @default(now())
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  deletedAt                 DateTime?
  agentMemories             AgentMemory[]
  responsibleUser           User?                      @relation("ContactResponsible", fields: [responsibleUserId], references: [id])
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  addresses                 ContactAddress[]
  customFields              ContactCustomField[]
  notes                     ContactNote[]
  profile                   ContactProfile?
  segments                  ContactSegment[]
  contactSegmentMemberships ContactSegmentMembership[]
  contactTags               ContactTag[]
  timelineEvents            ContactTimelineEvent[]
  conversations             Conversation[]
  deals                     Deal[]
  flowSessions              FlowSession[]
  tasks                     Task[]
  contactJourneys           ContactJourney[]
  scheduledMessages         ScheduledMessage[]

  @@unique([tenantId, normalizedPhone])
  @@index([tenantId, name])
  @@index([tenantId, email])
  @@index([tenantId, score])
}

model ContactProfile {
  id          String   @id @default(uuid())
  contactId   String   @unique
  company     String?
  jobTitle    String?
  website     String?
  industry    String?
  employees   Int?
  revenue     Float?
  bio         String?
  preferences String   @default("{}")
  socialLinks String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ContactAddress {
  id         String   @id @default(uuid())
  contactId  String
  type       String   @default("billing")
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  zip        String?
  country    String?  @default("Brazil")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ContactCustomField {
  id         String   @id @default(uuid())
  contactId  String
  fieldName  String
  fieldValue String
  fieldType  String   @default("text")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, fieldName])
}

model ContactSegment {
  id           String                     @id @default(uuid())
  tenantId     String
  name         String
  description  String?
  criteria     String
  contactCount Int                        @default(0)
  isActive     Boolean                    @default(true)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  contactId    String?
  contact      Contact?                   @relation(fields: [contactId], references: [id])
  contacts     ContactSegmentMembership[]
}

model ContactSegmentMembership {
  id        String         @id @default(uuid())
  contactId String
  segmentId String
  addedAt   DateTime       @default(now())
  contact   Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  segment   ContactSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([contactId, segmentId])
}

model ContactNote {
  id        String   @id @default(uuid())
  contactId String
  userId    String?
  content   String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ContactTimelineEvent {
  id          String   @id @default(uuid())
  contactId   String
  eventType   String
  title       String
  description String?
  metadata    String?  @default("{}")
  createdAt   DateTime @default(now())
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
}

model Tag {
  id          String       @id @default(uuid())
  name        String
  color       String       @default("#7C3AED")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  contactTags ContactTag[]
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model Conversation {
  id                         String                      @id @default(uuid())
  tenantId                   String
  contactId                  String
  channelId                  String?
  departmentId               String?
  assignedUserId             String?
  status                     String                      @default("new")
  priority                   String                      @default("normal")
  subject                    String?
  lastMessageAt              DateTime?
  lastCustomerMessageAt      DateTime?
  lastUserMessageAt          DateTime?
  waitStartedAt              DateTime?
  claimedAt                  DateTime?
  resolvedAt                 DateTime?
  closedAt                   DateTime?
  slaFirstResponseDueAt      DateTime?
  slaResolutionDueAt         DateTime?
  unreadCount                Int                         @default(0)
  aiLeadScore                Int?
  aiLeadLabel                String?
  aiSummary                  String?
  version                    Int                         @default(0)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  deletedAt                  DateTime?
  assignedUser               User?                       @relation("AssignedConversations", fields: [assignedUserId], references: [id])
  channel                    WhatsappConnection?         @relation("ChannelConversations", fields: [channelId], references: [id])
  contact                    Contact                     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  department                 Department?                 @relation(fields: [departmentId], references: [id])
  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments                ConversationAssignment[]
  internalNotes              ConversationInternalNote[]
  participants               ConversationParticipant[]
  conversationRoutingFilters ConversationRoutingFilter[]
  slaEvents                  ConversationSlaEvent[]
  transfers                  ConversationTransfer[]
  whispers                   ConversationWhisper[]
  deals                      Deal[]
  flowSessions               FlowSession[]
  messages                   Message[]
  routingLogs                RoutingLog[]
  tasks                      Task[]

  @@index([tenantId, status])
  @@index([tenantId, assignedUserId])
  @@index([tenantId, departmentId])
  @@index([tenantId, contactId])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ConversationAssignment {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  assignedBy     String?
  assignedAt     DateTime     @default(now())
  unassignedAt   DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ConversationTransfer {
  id               String       @id @default(uuid())
  conversationId   String
  fromUserId       String?
  toUserId         String?
  fromDepartmentId String?
  toDepartmentId   String?
  transferredBy    String
  reason           String?
  transferredAt    DateTime     @default(now())
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ConversationInternalNote {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ConversationWhisper {
  id             String       @id @default(uuid())
  conversationId String
  fromUserId     String
  toUserId       String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ConversationSlaEvent {
  id             String       @id @default(uuid())
  conversationId String
  eventType      String
  triggeredAt    DateTime     @default(now())
  resolvedAt     DateTime?
  notifiedUsers  String       @default("[]")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, eventType])
}

model Message {
  id               String              @id @default(uuid())
  tenantId         String
  conversationId   String
  senderType       String
  senderId         String?
  senderName       String?
  body             String
  type             String              @default("text")
  mediaUrl         String?
  mimeType         String?
  fileName         String?
  fileSize         Int?
  latitude         Float?
  longitude        Float?
  signatureUsed    String?
  isRead           Boolean             @default(false)
  channelMessageId String?
  provider         String?             @default("whatsapp")
  status           String?             @default("sent")
  errorText        String?
  metadataJson     String?             @default("{}")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  conversation     Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments      MessageAttachment[]
  reactions        MessageReaction[]
  statuses         MessageStatus[]

  @@index([tenantId, conversationId])
  @@index([tenantId, createdAt])
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  url       String
  mimeType  String
  name      String?
  size      Int?
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MessageStatus {
  id        String   @id @default(uuid())
  messageId String
  status    String
  errorText String?
  updatedAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String?
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model QuickReply {
  id           String    @id @default(uuid())
  tenantId     String
  shortcut     String
  title        String?
  message      String
  category     String?
  departmentId String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, shortcut])
}

model QuickReplyCategory {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  icon      String?
  color     String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MessageTemplate {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  category   String    @default("UTILITY")
  language   String    @default("pt_BR")
  body       String
  variables  String?   @default("[]")
  status     String    @default("approved")
  externalId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name, language])
}

model Pipeline {
  id        String          @id @default(uuid())
  tenantId  String
  name      String
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?
  deals     Deal[]
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages    PipelineStage[]

  @@unique([tenantId, isDefault])
}

model PipelineStage {
  id         String    @id @default(uuid())
  pipelineId String
  name       String
  position   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
