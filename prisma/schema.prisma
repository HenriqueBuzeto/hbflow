  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  deliveries      WebhookDelivery[]
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model WebhookDelivery {
  id            String          @id @default(uuid())
  endpointId    String
  eventId       String
  eventType     String
  payload       String
  status        String          @default("pending")
  statusCode    Int?
  response      String?
  attemptCount  Int             @default(0)
  nextAttemptAt DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  endpoint      WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
}

model Integration {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  type       String
  config     String    @default("{}")
  isActive   Boolean   @default(true)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SystemEvent {
  id        String   @id @default(uuid())
  tenantId  String?
  eventType String
  severity  String   @default("info")
  message   String
  metadata  String?  @default("{}")
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

model ErrorLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  path      String?
  method    String?
  message   String
  stack     String?
  metadata  String?  @default("{}")
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

model UserPresence {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String   @unique
  presence   String   @default("offline")
  lastSeen   DateTime @default(now())
  deviceInfo String?  @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RealtimeEvent {
  id         String   @id @default(uuid())
  tenantId   String
  eventType  String
  entityId   String?
  entityType String?
  payload    String   @default("{}")
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([eventType, createdAt])
}

model File {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  originalName String?
  mimeType     String
  size         Int
  url          String
  storagePath  String?
  uploadedBy   String?
  entityType   String?
  entityId     String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model FeatureFlag {
  id                String              @id @default(uuid())
  key               String              @unique
  name              String
  description       String?
  category          String              @default("general")
  isEnabled         Boolean             @default(false)
  rolloutPercentage Int                 @default(0)
  owner             String?
  expiresAt         DateTime?
  metadataJson      String              @default("{}")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  tenantOverrides   TenantFeatureFlag[]
  auditLogs         AuditLog[]          @relation("AuditLogToFeatureFlag")
}

model TenantFeatureFlag {
  id            String      @id @default(uuid())
  tenantId      String
  featureFlagId String
  isEnabled     Boolean     @default(false)
  overriddenBy  String?
  overriddenAt  DateTime    @default(now())
  metadataJson  String      @default("{}")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  featureFlag   FeatureFlag         @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureFlagId])
}

model Plan {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  priceCents   Int
  billingCycle String         @default("monthly") // monthly | yearly
  isActive     Boolean        @default(true)
  featuresJson String         @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  subscriptions Subscription[]
}

model Subscription {
  id                 String    @id @default(uuid())
  tenantId           String
  planId             String
  status             String    @default("trialing") // trialing | active | past_due | suspended | cancelled | free
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  plan               Plan      @relation(fields: [planId], references: [id])
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices           Invoice[]

  @@index([tenantId])
}

model Coupon {
  id                      String             @id @default(uuid())
  code                    String             @unique
  type                    String             @default("percentage") // percentage | fixed_amount | free_access
  value                   Float // value of discount: e.g. 20.0 for 20% or 1000 for 10.00 R$
  duration                String             @default("once") // once | months | forever
  durationMonths          Int?
  maxRedemptions          Int?
  redeemedCount           Int                @default(0)
  validFrom               DateTime?
  validUntil              DateTime?
  isActive                Boolean            @default(true)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  deletedAt               DateTime?
  discounts               TenantDiscount[]
  appliesToPlanSlug       String?
  maxRedemptionsPerTenant Int?
  isSystemCoupon          Boolean            @default(false)
  metadataJson            String?            @default("{}")
  redemptions             CouponRedemption[]
}

model CouponRedemption {
  id            String   @id @default(uuid())
  tenantId      String
  couponId      String
  invoiceId     String?
  redeemedAt    DateTime @default(now())
  discountCents Int
  metadataJson  String?  @default("{}")
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([couponId])
}

model TenantDiscount {
  id              String    @id @default(uuid())
  tenantId        String
  couponId        String?
  type            String    @default("percentage") // percentage | fixed_amount | free_access
  value           Float
  reason          String
  startsAt        DateTime  @default(now())
  endsAt          DateTime?
  isActive        Boolean   @default(true)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  coupon          Coupon?   @relation(fields: [couponId], references: [id], onDelete: SetNull)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User?     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model Invoice {
  id                 String        @id @default(uuid())
  tenantId           String
  subscriptionId     String?
  invoiceNumber      String        @unique
  status             String        @default("draft") // draft | open | paid | overdue | cancelled | void
  subtotalCents      Int
  discountCents      Int
  totalCents         Int
  dueDate            DateTime
  paidAt             DateTime?
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  metadataJson       String?       @default("{}")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?
  subscription       Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments           Payment[]
  pixCharges         PixCharge[]

  @@index([tenantId])
}

model Payment {
  id           String      @id @default(uuid())
  tenantId     String
  invoiceId    String
  provider     String      @default("manual_pix") // manual_pix | asaas | mercado_pago | stripe | internal
  method       String      @default("pix") // pix
  status       String      @default("pending") // pending | paid | failed | expired | refunded
  amountCents  Int
  paidAt       DateTime?
  externalId   String?
  metadataJson String      @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  invoice      Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pixCharges   PixCharge[]

  @@index([tenantId])
  @@index([invoiceId])
}

model PixCharge {
  id             String    @id @default(uuid())
  tenantId       String
  invoiceId      String
  paymentId      String?
  amountCents    Int
  qrCode         String
  qrCodeImageUrl String?
  copyPasteCode  String
  expiresAt      DateTime
  status         String    @default("active") // active | paid | expired | cancelled
  provider       String    @default("manual_pix")
  externalId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoice        Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment        Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
}

model Journey {
  id               String            @id @default(uuid())
  tenantId         String
  name             String
  description      String?
  trigger          String            // manual, tag_added, deal_won, sale_completed, conversation_closed, task_completed, custom
  triggerConfig    String?           // JSON
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps            JourneyStep[]
  contactJourneys  ContactJourney[]
  scheduledMessages ScheduledMessage[]
  journeyEventLogs JourneyEventLog[]

  @@index([tenantId])
}

model JourneyStep {
  id               String            @id @default(uuid())
  journeyId        String
  name             String
  delayValue       Int
  delayUnit        String            // minutes, hours, days, weeks, months, years
  message          String
  channel          String            @default("whatsapp")
  isActive         Boolean           @default(true)
  order            Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  journey          Journey           @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  scheduledMessages ScheduledMessage[]

  @@index([journeyId])
}

model ContactJourney {
  id               String            @id @default(uuid())
  tenantId         String
  contactId        String
  journeyId        String
  status           String            @default("active") // active, completed, cancelled
  currentStepId    String?
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact          Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  journey          Journey           @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  scheduledMessages ScheduledMessage[]

  @@index([tenantId])
  @@index([contactId])
  @@index([journeyId])
}

model JourneyEventLog {
  id               String            @id @default(uuid())
  tenantId         String
  journeyId        String
  contactId        String?
  action           String            // journey.started, journey.completed, etc.
  metadata         String?           // JSON
  createdAt        DateTime          @default(now())
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journey          Journey           @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([journeyId])
}

model InternalMessage {
  id         String   @id @default(uuid())
  tenantId   String
  senderId   String
  receiverId String
  body       String
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentInternalMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedInternalMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([tenantId, senderId, receiverId])
  @@index([tenantId, createdAt])
}
